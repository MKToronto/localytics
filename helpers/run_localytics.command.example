#!/bin/bash
# Double-clickable macOS launcher. Copy to `run_localytics.command`,
# chmod +x, double-click in Finder. Uses `uv run` — no venv setup needed.
# Conda users: replace the last line with `conda activate <env> && python …`.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Finder launches with a minimal PATH — make uv reachable.
export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

cd "$REPO_DIR"
uv run "$REPO_DIR/server/local_server.py"
